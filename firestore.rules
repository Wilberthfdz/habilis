rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /tecnicos/{uid} {
      allow read:   if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    match /trabajos/{trabajoId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.tecnicoId == request.auth.uid;
      allow delete: if false;
    }

    match /solicitudes/{solicitudId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // Habilis Care — equipment assets (owner only)
    match /activos/{activoId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Service history records
    match /servicios/{servicioId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Care subscription plans
    match /planes_care/{planId} {
      allow read:   if request.auth != null && resource.data.clienteId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.clienteId == request.auth.uid;
      allow delete: if false;
    }

    // Cotizaciones — public read (cotizacionId is the "token"), owner write
    match /cotizaciones/{cotId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if true;  // clients accept/reject without auth
      allow delete: if false;
    }

    // Folio counters (owner only)
    match /cotizaciones_folio/{tecnicoId} {
      allow read:   if request.auth != null && request.auth.uid == tecnicoId;
      allow write:  if request.auth != null && request.auth.uid == tecnicoId;
    }

    // Technician client directory
    match /clientes_tecnico/{clienteId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Technician product catalog
    match /productos_tecnico/{productoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Chat solicitudes — readable by both parties, writable by authenticated users
    match /solicitudes_chat/{solicitudId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;

      match /mensajes/{mensajeId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null;
        allow update: if false;
        allow delete: if false;
      }
    }

    // Social validations — one per user-work-type combination
    match /validaciones/{validacionId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    // Technician collaboration network (subcollection per user)
    match /red_colaboradores/{userId}/lista/{tecnicoId} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null && request.auth.uid == userId;
    }
  }
}
